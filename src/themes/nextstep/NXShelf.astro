---
import { shelfItems } from "./nx-icons";
---

<aside class="nx-shelf" role="navigation" aria-label="Window shelf">
  {shelfItems.map((item) => (
    <button
      class="nx-shelf-item"
      data-action="open-window"
      data-target={item.windowId}
      data-shelf-item={item.windowId}
      aria-label={`Open ${item.label}`}
    >
      <span class="nx-shelf-icon">{item.icon}</span>
      <span class="nx-shelf-label">{item.label}</span>
    </button>
  ))}
</aside>

<style>
  .nx-shelf {
    position: fixed;
    right: 0;
    top: 0;
    bottom: 0;
    width: 72px;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 2rem;
    gap: 0.25rem;
    background: var(--nx-shelf-bg, #1a1a1e);
    border-left: 1px solid var(--nx-shelf-border, #3a3a40);
    z-index: 100;
  }

  .nx-shelf-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 60px;
    padding: 0.5rem 0.25rem;
    gap: 0.2rem;
    background: transparent;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    color: var(--nx-shelf-text, #c0c0c8);
    transition: background 0.15s, color 0.15s;
    position: relative;
  }

  .nx-shelf-item:hover {
    background: var(--nx-shelf-hover, #2a2a30);
    color: #ffffff;
  }

  .nx-shelf-item.active {
    color: #6aafee;
  }

  .nx-shelf-item.active::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 3px;
    height: 60%;
    background: #6aafee;
    border-radius: 0 2px 2px 0;
  }

  .nx-shelf-icon {
    font-size: 1.4rem;
    line-height: 1;
  }

  .nx-shelf-label {
    font-size: 0.6rem;
    text-align: center;
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    letter-spacing: 0.02em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 56px;
  }
</style>
