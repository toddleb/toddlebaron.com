---
// src/themes/sgi-irix/Desktop.astro
export interface Props {
  windows: { windowId: string; title: string; icon: string }[];
}
const { windows } = Astro.props;
---

<div class="sgi-desktop" id="desktop">
  <div class="sgi-desktop-logo" aria-hidden="true">
    <span class="sgi-logo-s">s</span><span class="sgi-logo-g">g</span><span class="sgi-logo-i">i</span>
  </div>
  <div class="sgi-desktop-icons">
    {windows.map((w) => (
      <div class="sgi-icon" data-window-id={w.windowId} tabindex="0" role="button" aria-label={`Open ${w.title}`}>
        <div class="sgi-icon-image">{w.icon}</div>
        <div class="sgi-icon-label">{w.title}</div>
      </div>
    ))}
  </div>
  <slot />
</div>
