---
// src/themes/bbs/DeskPlant.astro — Potted succulent for daytime desk scene
---

<div class="desk-plant">
  <img src="/plant.png" alt="Potted succulent" draggable="false" />
  <div class="plant-gecko">
    <svg viewBox="0 0 40 20" width="31" height="15" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Body -->
      <ellipse cx="20" cy="10" rx="10" ry="4.5" fill="#5a8a4a" />
      <ellipse cx="20" cy="10" rx="8" ry="3.5" fill="#6a9a5a" />
      <!-- Head -->
      <ellipse cx="31" cy="10" rx="4" ry="3.5" fill="#5a8a4a" />
      <circle cx="33" cy="8.5" r="1" fill="#222" />
      <circle cx="33" cy="11.5" r="1" fill="#222" />
      <!-- Tail -->
      <path d="M10 10 Q4 8 1 12" stroke="#5a8a4a" stroke-width="2" stroke-linecap="round" fill="none" />
      <!-- Front legs -->
      <path d="M27 6.5 Q30 2 33 3" stroke="#5a8a4a" stroke-width="1.5" stroke-linecap="round" fill="none" />
      <path d="M27 13.5 Q30 18 33 17" stroke="#5a8a4a" stroke-width="1.5" stroke-linecap="round" fill="none" />
      <!-- Back legs -->
      <path d="M14 6.5 Q11 2 8 3" stroke="#5a8a4a" stroke-width="1.5" stroke-linecap="round" fill="none" />
      <path d="M14 13.5 Q11 18 8 17" stroke="#5a8a4a" stroke-width="1.5" stroke-linecap="round" fill="none" />
      <!-- Spine stripe -->
      <line x1="12" y1="10" x2="28" y2="10" stroke="#7ab06a" stroke-width="1" stroke-dasharray="2 2" />
    </svg>
  </div>
</div>
