    <div class="scarab-wing scarab-wing-l"></div>
    <div class="scarab-wing scarab-wing-r"></div>
    <div class="scarab-head"></div>
    <div class="scarab-legs">
      <span class="scarab-leg scarab-leg-1"></span>
      <span class="scarab-leg scarab-leg-2"></span>
      <span class="scarab-leg scarab-leg-3"></span>
      <span class="scarab-leg scarab-leg-4"></span>
      <span class="scarab-leg scarab-leg-5"></span>
      <span class="scarab-leg scarab-leg-6"></span>
    </div>
  </div>
</div>
