---
// T-NET BBS — Boot Sequence
// Phase 1: Modem dial-up text + AUDIO
// Phase 1.5: WarGames "matrix" login (WOPR)
// Phase 2: Splash logo reveal
// Phase 3: Fade to main menu
---

<!-- Phase 1: Modem text -->
<div id="bbs-boot" class="bbs-boot" style="cursor:pointer">
  <div style="position:absolute;top:12px;right:16px;font-size:12px;" class="ansi-bright-black">
    click to skip
  </div>
  <div id="bbs-boot-lines" style="overflow-y:auto;flex:1;display:flex;flex-direction:column;justify-content:flex-end;"></div>
</div>

<!-- Phase 1.5: WarGames matrix -->
<div id="bbs-wargames-matrix" class="bbs-matrix" style="cursor:pointer">
  <div id="bbs-matrix-text" style="max-width:600px;margin:0 auto;padding:40px 24px;"></div>
</div>

<!-- Phase 2: Splash -->
<div id="bbs-splash" class="bbs-splash">
  <div class="bbs-splash-logo">
    <div class="bbs-splash-title">T – N E T</div>
    <div class="bbs-splash-sub">B  B  S</div>
    <div class="bbs-splash-line"></div>
    <div class="bbs-splash-tagline">PERSONAL NETWORK OF TODD LEBARON · EST. 1984</div>
  </div>
</div>

<script>
  import { playModemHandshake, playDisconnect, speakWOPR, playTHXDeepNote } from "../../engine/modem-audio";

  // Expose disconnect for logoff
  (window as any).__modemDisconnect = playDisconnect;

  const modemLines = [
    { text: "HAYES SMARTMODEM 14400 — FIRMWARE v4.20", color: "ansi-bright-black", delay: 150 },
    { text: "", delay: 100 },
    { text: "ATZ", color: "tf-orange", delay: 200 },
    { text: "OK", color: "ansi-bright-white", delay: 250 },
    { text: "ATS0=0 E1 V1 Q0 &C1 &D2", color: "tf-orange", delay: 200 },
    { text: "OK", color: "ansi-bright-white", delay: 200 },
    { text: "", delay: 150 },
    { text: "ATDT 1-512-555-TODD", color: "tf-orange", delay: 400 },
    { text: "", delay: 200 },
    { text: "DIALING...", color: "ansi-bright-black", delay: 600 },
    { text: "", delay: 200 },
    { text: "RING...", color: "tf-orange-bright", delay: 800 },
    { text: "RING...", color: "tf-orange-bright", delay: 800 },
    { text: "", delay: 200 },
    { text: "CONNECT 14400/ARQ/V.32bis/LAPM/V.42bis", color: "tf-purple-bright", delay: 400 },
    { text: "", delay: 300 },
    { text: "═══════════════════════════════════════════", color: "tf-purple", delay: 100 },
    { text: "", delay: 100 },
    { text: "Detecting terminal... ANSI color ✓", color: "ansi-green", delay: 200 },
    { text: "Checking for ANSI graphics... ████████████████ YES", color: "tf-orange", delay: 300 },
    { text: "Negotiating encryption... ████████████████ OK", color: "ansi-green", delay: 250 },
    { text: "", delay: 100 },
    { text: "═══════════════════════════════════════════", color: "tf-purple", delay: 100 },
    { text: "", delay: 150 },
    { text: "  Connected to T-NET BBS", color: "tf-orange-bright", delay: 300 },
    { text: "  Est. 1984 · Scottsdale, AZ · Node 1 of 4", color: "ansi-bright-black", delay: 200 },
    { text: "", delay: 150 },
    { text: "  Handle: VISITOR", color: "tf-purple-bright", delay: 200 },
    { text: "  Access Level: Guest", color: "ansi-green", delay: 200 },
    { text: "  Messages: 3 NEW", color: "ansi-green", delay: 150 },
    { text: "  You are caller #48,291", color: "tf-gold", delay: 250 },
    { text: "", delay: 100 },
    { text: "  \"The machines changed. The mission didn't.\"", color: "ansi-bright-black", delay: 400 },
    { text: "", delay: 300 },
    { text: "Entering T-NET...", color: "tf-purple-bright", delay: 500 },
  ];

  const matrixLines = [
    { text: "WOPR STRATEGIC DEFENSE COMPUTER", color: "ansi-bright-green", delay: 400 },
    { text: "NORAD / USSTRATCOM", color: "ansi-green", delay: 300 },
    { text: "", delay: 200 },
    { text: "LOGON: JOSHUA", color: "ansi-green", delay: 600 },
    { text: "", delay: 400 },
    { text: "GREETINGS, PROFESSOR FALKEN.", color: "ansi-bright-green", delay: 800 },
    { text: "", delay: 300 },
    { text: "SHALL WE PLAY A GAME?", color: "ansi-bright-white", delay: 800 },
    { text: "", delay: 400 },
    { text: "> T-NET BBS", color: "ansi-bright-green", delay: 600 },
    { text: "", delay: 300 },
    { text: "EXCELLENT CHOICE.", color: "ansi-green", delay: 500 },
    { text: "CONNECTING TO NODE 1...", color: "ansi-green", delay: 600 },
  ];

  function escapeHtml(s: string): string {
    return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
  }

  function makeBootLine(text: string, color: string): HTMLDivElement {
    const el = document.createElement("div");
    el.className = "bbs-boot-line visible";
    if (color) {
      const span = document.createElement("span");
      span.className = color;
      span.textContent = text;
      el.appendChild(span);
    } else {
      el.textContent = " ";
    }
    return el;
  }

  function makeMatrixLine(text: string, color: string): HTMLDivElement {
    const div = document.createElement("div");
    div.style.whiteSpace = "pre-wrap";
    div.style.marginBottom = "4px";
    div.style.fontFamily = "var(--bbs-font)";
    div.style.fontSize = "var(--bbs-font-size)";
    if (text) {
      const span = document.createElement("span");
      span.className = color;
      span.textContent = text;
      div.appendChild(span);
    } else {
      div.textContent = " ";
    }
    return div;
  }

  // ─── Boot sequence runner (reusable for reboot) ───
  function runBootSequence() {
    let aborted = false;
    let sharedBootCtx: AudioContext | null = null;
    const screenContent = document.querySelector(".hw-screen-content") as HTMLElement;
    const mainEl = document.getElementById("bbs-main")!;

    // Build overlay elements fresh
    const bootEl = document.createElement("div");
    bootEl.className = "bbs-boot";
    bootEl.style.cursor = "pointer";

    const skipHint = document.createElement("div");
    skipHint.style.cssText = "position:absolute;top:12px;right:16px;font-size:12px;";
    skipHint.className = "ansi-bright-black";
    skipHint.textContent = "click to skip";
    bootEl.appendChild(skipHint);

    const linesEl = document.createElement("div");
    linesEl.style.cssText = "overflow-y:auto;flex:1;display:flex;flex-direction:column;justify-content:flex-end;";
    bootEl.appendChild(linesEl);

    const matrixEl = document.createElement("div");
    matrixEl.className = "bbs-matrix";
    matrixEl.style.cursor = "pointer";
    const matrixTextEl = document.createElement("div");
    matrixTextEl.style.cssText = "max-width:600px;margin:0 auto;padding:40px 24px;";
    matrixEl.appendChild(matrixTextEl);

    const splashEl = document.createElement("div");
    splashEl.className = "bbs-splash";
    splashEl.innerHTML = [
      '<div class="bbs-splash-logo">',
      '<div class="bbs-splash-title">T &ndash; N E T</div>',
      '<div class="bbs-splash-sub">B  B  S</div>',
      '<div class="bbs-splash-line"></div>',
      '<div class="bbs-splash-tagline">PERSONAL NETWORK OF TODD LEBARON &middot; EST. 1984</div>',
      '</div>',
    ].join("");

    // Hide main, inject overlays
    mainEl.style.display = "none";
    screenContent.prepend(splashEl, matrixEl, bootEl);

    // Play audio — called from user click so browser allows it
    sharedBootCtx = new AudioContext();
    playModemHandshake(sharedBootCtx).catch(() => {});

    // Modem text lines
    let totalDelay = 0;
    modemLines.forEach((line) => {
      totalDelay += line.delay;
      setTimeout(() => {
        if (aborted) return;
        linesEl.appendChild(makeBootLine(line.text, line.color));
        linesEl.scrollTop = linesEl.scrollHeight;
      }, totalDelay);
    });

    // Phase 1.5: WarGames matrix
    const matrixStart = totalDelay + 400;
    setTimeout(() => {
      if (aborted) return;
      bootEl.style.transition = "opacity 0.3s";
      bootEl.style.opacity = "0";
      setTimeout(() => bootEl.remove(), 300);
      matrixEl.classList.add("visible");

      const speechPromises: Promise<void>[] = [];
      let d = 0;
      for (const line of matrixLines) {
        d += line.delay;
        const lineText = line.text;
        const lineColor = line.color;
        setTimeout(() => {
          if (aborted) return;
          matrixTextEl.appendChild(makeMatrixLine(lineText, lineColor));
          // WOPR voice for iconic lines
          if (lineText === "GREETINGS, PROFESSOR FALKEN." || lineText === "SHALL WE PLAY A GAME?" || lineText === "EXCELLENT CHOICE.") {
            speechPromises.push(speakWOPR(lineText).catch(() => {}));
          }
        }, d);
      }

      // Wait for all text to appear + all speech to finish, then splash + THX
      const allTextDone = d + 600;
      setTimeout(async () => {
        if (aborted) return;
        // Wait for any speech still playing
        await Promise.all(speechPromises);
        if (aborted) return;

        // Matrix → splash
        matrixEl.style.transition = "opacity 0.4s";
        matrixEl.style.opacity = "0";
        setTimeout(() => matrixEl.remove(), 400);
        splashEl.classList.add("visible");

        // THX deep note on splash reveal
        playTHXDeepNote(sharedBootCtx || undefined).catch(() => {});

        // Splash → main after THX plays (~4.5s)
        setTimeout(() => {
          if (aborted) return;
          finish();
        }, 4500);
      }, allTextDone);
    }, matrixStart);

    function skipAll() {
      aborted = true;
      if (sharedBootCtx) { sharedBootCtx.close(); sharedBootCtx = null; }
      [bootEl, matrixEl, splashEl].forEach((el) => {
        el.style.transition = "opacity 0.15s";
        el.style.opacity = "0";
      });
      mainEl.style.display = "";
      setTimeout(() => {
        bootEl.remove();
        matrixEl.remove();
        splashEl.remove();
        document.dispatchEvent(new CustomEvent("boot:complete"));
      }, 150);
      document.cookie = "toddlebaron-visited=1;path=/;max-age=" + (365 * 86400);
    }

    function finish() {
      if (sharedBootCtx) { sharedBootCtx.close(); sharedBootCtx = null; }
      splashEl.style.transition = "opacity 0.6s ease-out";
      splashEl.style.opacity = "0";
      mainEl.style.display = "";
      setTimeout(() => {
        splashEl.remove();
        document.dispatchEvent(new CustomEvent("boot:complete"));
      }, 600);
      document.cookie = "toddlebaron-visited=1;path=/;max-age=" + (365 * 86400);
    }

    bootEl.addEventListener("click", skipAll);
    matrixEl.addEventListener("click", skipAll);
    splashEl.addEventListener("click", skipAll);
  }

  // Expose reboot for Terminal.astro
  (window as any).__rebootBBS = runBootSequence;

  // ─── Initial boot on first visit ───
  const bootEl = document.getElementById("bbs-boot")!;
  const linesEl = document.getElementById("bbs-boot-lines")!;
  const matrixEl = document.getElementById("bbs-wargames-matrix")!;
  const matrixText = document.getElementById("bbs-matrix-text")!;
  const splashEl = document.getElementById("bbs-splash")!;
  let aborted = false;
  let sharedBootCtx: AudioContext | null = null;

  const visited = document.cookie.includes("toddlebaron-visited=1");
  if (visited) {
    bootEl.remove();
    matrixEl.remove();
    splashEl.remove();
    document.getElementById("bbs-main")!.style.display = "";
    requestAnimationFrame(() => document.dispatchEvent(new CustomEvent("boot:complete")));
  } else {
    // Start modem audio
    let audioPlaying = false;
    function startAudio() {
      if (audioPlaying) return;
      audioPlaying = true;
      sharedBootCtx = new AudioContext();
      playModemHandshake(sharedBootCtx).catch(() => { audioPlaying = false; });
    }
    startAudio();
    document.addEventListener("click", startAudio, { once: true });
    document.addEventListener("keydown", startAudio, { once: true });
    document.addEventListener("touchstart", startAudio, { once: true });

    let totalDelay = 0;
    modemLines.forEach((line) => {
      totalDelay += line.delay;
      setTimeout(() => {
        if (aborted) return;
        linesEl.appendChild(makeBootLine(line.text, line.color));
        linesEl.scrollTop = linesEl.scrollHeight;
      }, totalDelay);
    });

    // Phase 1.5: WarGames matrix login
    const matrixStart = totalDelay + 400;
    setTimeout(() => {
      if (aborted) return;
      bootEl.style.transition = "opacity 0.3s";
      bootEl.style.opacity = "0";
      setTimeout(() => bootEl.remove(), 300);
      matrixEl.classList.add("visible");

      const speechPromises: Promise<void>[] = [];
      let d = 0;
      for (const line of matrixLines) {
        d += line.delay;
        const lineText = line.text;
        const lineColor = line.color;
        setTimeout(() => {
          if (aborted) return;
          matrixText.appendChild(makeMatrixLine(lineText, lineColor));
          // WOPR voice for iconic lines
          if (lineText === "GREETINGS, PROFESSOR FALKEN." || lineText === "SHALL WE PLAY A GAME?" || lineText === "EXCELLENT CHOICE.") {
            speechPromises.push(speakWOPR(lineText).catch(() => {}));
          }
        }, d);
      }

      // Wait for all text + speech to finish, then splash + THX
      const allTextDone = d + 600;
      setTimeout(async () => {
        if (aborted) return;
        await Promise.all(speechPromises);
        if (aborted) return;

        // Matrix → splash
        matrixEl.style.transition = "opacity 0.4s";
        matrixEl.style.opacity = "0";
        setTimeout(() => matrixEl.remove(), 400);
        splashEl.classList.add("visible");

        // THX deep note on splash reveal
        playTHXDeepNote(sharedBootCtx || undefined).catch(() => {});

        // Splash → main after THX plays (~4.5s)
        setTimeout(() => {
          if (aborted) return;
          finishBoot();
        }, 4500);
      }, allTextDone);
    }, matrixStart);

    bootEl.addEventListener("click", skipAll);
    matrixEl.addEventListener("click", skipAll);
    splashEl.addEventListener("click", skipAll);
  }

  function skipAll() {
    aborted = true;
    if ("speechSynthesis" in window) speechSynthesis.cancel();
    if (sharedBootCtx) { sharedBootCtx.close(); sharedBootCtx = null; }
    [bootEl, matrixEl, splashEl].forEach((el) => {
      el.style.transition = "opacity 0.15s";
      el.style.opacity = "0";
    });
    document.getElementById("bbs-main")!.style.display = "";
    setTimeout(() => {
      bootEl.remove();
      matrixEl.remove();
      splashEl.remove();
      document.dispatchEvent(new CustomEvent("boot:complete"));
    }, 150);
    document.cookie = "toddlebaron-visited=1;path=/;max-age=" + (365 * 86400);
  }

  function finishBoot() {
    if (sharedBootCtx) { sharedBootCtx.close(); sharedBootCtx = null; }
    splashEl.style.transition = "opacity 0.6s ease-out";
    splashEl.style.opacity = "0";
    document.getElementById("bbs-main")!.style.display = "";
    setTimeout(() => {
      splashEl.remove();
      document.dispatchEvent(new CustomEvent("boot:complete"));
    }, 600);
    document.cookie = "toddlebaron-visited=1;path=/;max-age=" + (365 * 86400);
  }
</script>
