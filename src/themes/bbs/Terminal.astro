  <!-- ═══ WarGames Door ═══ -->
  <section id="bbs-screen-wargames" class="bbs-screen">
    <pre class="bbs-section-header"><span class="tf-purple">═══════════════════════════════════════════════</span>
<span class="tf-orange">   G L O B A L   T H E R M O N U C L E A R</span>
<span class="tf-orange">              W A R</span>
<span class="tf-purple">═══════════════════════════════════════════════</span></pre>

    <div id="wargames-container" style="max-width:700px;margin:0 auto;padding:0 16px;">
      <div id="wargames-output" style="min-height:300px;margin-bottom:16px;"></div>
      <div style="display:flex;gap:8px;align-items:center;">
        <span class="ansi-green">></span>
        <input id="wargames-input" type="text" autocomplete="off" spellcheck="false"
          style="flex:1;background:#0a0a0a;border:1px solid #1a3a1a;color:#33ff33;font-family:var(--bbs-font);font-size:var(--bbs-font-size);padding:6px 10px;outline:none;"
          placeholder="ENTER COMMAND..."
        />
