  <!-- ═══ Logoff Overlay ═══ -->
  <div id="bbs-logoff" class="bbs-logoff">
    <div class="bbs-logoff-text">
      <div class="tf-purple-bright">Thank you for calling</div>
      <div class="tf-orange" style="font-size:28px;letter-spacing:6px;margin:8px 0;">T – N E T</div>
      <div class="ansi-white"></div>
      <div class="ansi-white">"The machines changed.</div>
      <div class="ansi-white"> The mission didn't."</div>
      <div class="ansi-white"></div>
      <div class="tf-purple-bright" style="font-size:12px;margin:8px 0;">See you next time.</div>
      <div class="ansi-bright-black" style="margin:4px 0;">Disconnecting from node 1...</div>
      <div class="ansi-bright-white" style="font-size:24px;margin-top:12px;">NO CARRIER</div>
    </div>
  </div>
</div>


<script>
  // ═══ Terminal Navigation ═══
  let currentScreen = "menu";

  function showScreen(id: string): void {
    document.querySelectorAll<HTMLElement>(".bbs-screen").forEach((s) => s.classList.remove("bbs-active"));
    const target = document.getElementById(`bbs-screen-${id}`);
    if (target) {
      target.classList.add("bbs-active");
      currentScreen = id;
      document.getElementById("bbs-terminal")?.scrollTo(0, 0);

      if (id === "adventure") {
        setTimeout(() => document.getElementById("adventure-input")?.focus(), 100);
      }
      if (id === "wargames") {
        setTimeout(() => {
          document.getElementById("wargames-input")?.focus();
          initWarGames();
        }, 100);
      }
    }
  }

  function goBack(): void { showScreen("menu"); }

  const keyMap: Record<string, string> = {
    a: "about", b: "blog", d: "doors", f: "files",
    h: "computing-history", m: "contact", r: "resume",
    v: "voting", g: "goodbye",
  };

  document.addEventListener("keydown", (e) => {
    if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) {
      if (e.key === "Escape") { goBack(); e.preventDefault(); }
      return;
    }
    if (e.key === "Escape") { goBack(); return; }
    if (currentScreen !== "menu") return;
    const target = keyMap[e.key.toLowerCase()];
    if (!target) return;
    if (target === "goodbye") triggerLogoff();
    else showScreen(target);
  });

  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    const menuItem = target.closest<HTMLElement>("[data-bbs-nav]");
    if (menuItem) {
      const nav = menuItem.dataset.bbsNav!;
      if (nav === "goodbye") triggerLogoff();
      else showScreen(nav);
      return;
    }
    const backBtn = target.closest("[data-bbs-back]");
    if (backBtn) { goBack(); return; }
  });

  function triggerLogoff(): void {
    const logoff = document.getElementById("bbs-logoff");
    if (!logoff) return;
    logoff.classList.add("active");
    try { (window as any).__modemDisconnect?.(); } catch {}
    setTimeout(() => location.reload(), 3500);
  }

  // ═══ Voting Booth ═══
  const fakeResults: Record<string, Record<string, number>> = {
    modem: { usr: 847, hayes: 312, zoom: 98, telebit: 45 },
    captain: { kirk: 523, picard: 891, sisko: 234, janeway: 167 },
    doorgame: { lord: 1247, tw2002: 893, bre: 456, usurper: 321 },
    os: { dos: 634, os2: 287, amiga: 512, linux: 891 },
    villain: { vader: 1102, t1000: 743, gruber: 567, biff: 234 },
    tabs: { tabs: 567, spaces: 612, both: 89, butterflies: 234 },
    pizza: { yes: 445, no: 678, war: 312 },
    movie: { gf1: 1456, gf2: 1123, gf3: 47 },
  };

  document.querySelectorAll<HTMLElement>(".bbs-poll-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const poll = btn.closest<HTMLElement>(".bbs-poll");
      if (!poll) return;
      const pollId = poll.dataset.poll!;
      const vote = btn.dataset.vote!;

      // Check if already voted
      const voted = localStorage.getItem(`bbs-vote-${pollId}`);
      if (voted) return;

      localStorage.setItem(`bbs-vote-${pollId}`, vote);

      // Add user's vote
      const results = fakeResults[pollId] || {};
      results[vote] = (results[vote] || 0) + 1;

      // Show results
      showPollResults(poll, pollId, results, vote);
    });
  });

  function showPollResults(poll: HTMLElement, pollId: string, results: Record<string, number>, userVote: string): void {
    const total = Object.values(results).reduce((a, b) => a + b, 0);
    const resultsEl = poll.querySelector(".bbs-poll-results")!;
    const optionsEl = poll.querySelector(".bbs-poll-options")!;
    optionsEl.classList.add("voted");

    let html = '<div style="margin-top:8px;">';
    const sorted = Object.entries(results).sort(([,a], [,b]) => b - a);
    for (const [key, count] of sorted) {
      const pct = Math.round((count / total) * 100);
      const barWidth = Math.max(1, pct);
      const isUser = key === userVote;
      const label = poll.querySelector(`[data-vote="${key}"]`)?.textContent || key;
      html += `<div style="margin:3px 0;font-size:14px;">`;
      html += `<span class="${isUser ? 'tf-orange' : 'ansi-white'}">${label}</span>`;
      html += ` <span class="ansi-bright-black">${pct}%</span>`;
      html += `<div style="background:${isUser ? 'var(--tf-orange)' : 'var(--tf-purple)'};height:8px;width:${barWidth}%;border-radius:2px;margin-top:2px;opacity:0.7;"></div>`;
      html += `</div>`;
    }
    html += `<div class="ansi-bright-black" style="font-size:12px;margin-top:6px;">${total} votes cast</div>`;
    html += '</div>';
    resultsEl.innerHTML = html;
  }

  // Restore previous votes on load
  document.querySelectorAll<HTMLElement>(".bbs-poll").forEach((poll) => {
    const pollId = poll.dataset.poll!;
    const voted = localStorage.getItem(`bbs-vote-${pollId}`);
    if (voted && fakeResults[pollId]) {
      fakeResults[pollId][voted] = (fakeResults[pollId][voted] || 0) + 1;
      showPollResults(poll, pollId, fakeResults[pollId], voted);
    }
  });

  // ═══ WarGames Door ═══
  let wargamesInit = false;
  const wgOutput = document.getElementById("wargames-output")!;
  const wgInput = document.getElementById("wargames-input") as HTMLInputElement;
  let wgState = "login";

  function wgPrint(text: string, color = "ansi-green"): void {
    const div = document.createElement("div");
    div.style.marginBottom = "4px";
    div.style.whiteSpace = "pre-wrap";
    div.innerHTML = `<span class="${color}">${text}</span>`;
    wgOutput.appendChild(div);
    wgOutput.scrollTop = wgOutput.scrollHeight;
  }

  function wgTypewriter(text: string, color: string, delay: number): Promise<void> {
    return new Promise((resolve) => {
      const div = document.createElement("div");
      div.style.whiteSpace = "pre-wrap";
      div.innerHTML = `<span class="${color}"></span>`;
      wgOutput.appendChild(div);
      const span = div.querySelector("span")!;
      let i = 0;
      const timer = setInterval(() => {
        if (i < text.length) {
          span.textContent += text[i];
          i++;
          wgOutput.scrollTop = wgOutput.scrollHeight;
        } else {
          clearInterval(timer);
          resolve();
        }
      }, delay);
    });
  }

  async function initWarGames(): Promise<void> {
    if (wargamesInit) return;
    wargamesInit = true;
    wgState = "login";

    wgPrint("WOPR STRATEGIC DEFENSE COMPUTER", "ansi-bright-green");
    wgPrint("UNITED STATES STRATEGIC COMMAND", "ansi-green");
    wgPrint("OFFUTT AIR FORCE BASE, OMAHA, NEBRASKA", "ansi-green");
    wgPrint("", "ansi-green");
    wgPrint("WARNING: UNAUTHORIZED ACCESS IS A FEDERAL CRIME", "ansi-bright-red");
    wgPrint("PUNISHABLE UNDER 18 U.S.C. § 1030", "ansi-red");
    wgPrint("", "ansi-green");
    await wgTypewriter("LOGON: ", "ansi-green", 40);
    wgState = "password";
  }

  function processWarGames(cmd: string): void {
    const c = cmd.trim().toLowerCase();

    if (wgState === "password") {
      if (c === "joshua" || c === "joshua1") {
        wgPrint(`\nLOGON: ${cmd}`, "ansi-green");
        wgPrint("", "ansi-green");
        wgState = "greeted";
        setTimeout(async () => {
          await wgTypewriter("GREETINGS, PROFESSOR FALKEN.", "ansi-bright-green", 50);
          wgPrint("", "ansi-green");
          await wgTypewriter("SHALL WE PLAY A GAME?", "ansi-bright-green", 50);
          wgPrint("", "ansi-green");
          wgPrint("AVAILABLE GAMES:", "ansi-green");
          wgPrint("", "ansi-green");
          wgPrint("  CHESS", "ansi-bright-green");
          wgPrint("  CHECKERS", "ansi-bright-green");
          wgPrint("  BACKGAMMON", "ansi-bright-green");
          wgPrint("  GLOBAL THERMONUCLEAR WAR", "ansi-bright-white");
          wgPrint("  THEATER-WIDE BIOTOXIC AND CHEMICAL WARFARE", "ansi-bright-green");
          wgPrint("", "ansi-green");
          wgPrint("WHICH GAME?", "ansi-green");
          wgState = "game";
        }, 300);
      } else {
        wgPrint(`\nLOGON: ${cmd}`, "ansi-green");
        wgPrint("IDENTIFICATION NOT RECOGNIZED.", "ansi-bright-red");
        wgPrint("", "ansi-green");
        wgPrint("HINT: The password is a name. A boy's name.", "ansi-bright-black");
        wgPrint("      (Think: what was Falken's son called?)", "ansi-bright-black");
      }
      return;
    }

    if (wgState === "game") {
      wgPrint(`\n> ${cmd}`, "ansi-bright-black");
      if (c.includes("thermonuclear") || c.includes("war") || c.includes("global")) {
        wgPrint("", "ansi-green");
        wgPrint("WOULDN'T YOU PREFER A NICE GAME OF CHESS?", "ansi-bright-green");
        wgPrint("", "ansi-green");
        wgState = "chess_or_war";
      } else if (c.includes("chess")) {
        wgPrint("", "ansi-green");
        wgPrint("A WISE CHOICE, PROFESSOR.", "ansi-bright-green");
        wgPrint("", "ansi-green");
        wgPrint("UNFORTUNATELY, THE CHESS MODULE IS BEING", "ansi-green");
        wgPrint("MAINTAINED BY CAPTAIN LEBARON'S TEAM.", "ansi-green");
        wgPrint("", "ansi-green");
        wgPrint("FUN FACT: The real STRATCOM wargaming systems", "ansi-bright-black");
        wgPrint("were maintained by Todd LeBaron in the 1990s.", "ansi-bright-black");
        wgPrint("Yes, the SysOp of this BBS ran the actual WOPR.", "ansi-bright-black");
        wgPrint("", "ansi-green");
        wgPrint("SHALL WE PLAY A DIFFERENT GAME?", "ansi-green");
      } else {
        wgPrint("", "ansi-green");
        wgPrint(`THAT GAME IS NOT AVAILABLE. TRY AGAIN.`, "ansi-green");
      }
      return;
    }

    if (wgState === "chess_or_war") {
      wgPrint(`\n> ${cmd}`, "ansi-bright-black");
      if (c.includes("war") || c.includes("no") || c.includes("thermonuclear")) {
        wgPrint("", "ansi-green");
        wgPrint("FINE.", "ansi-bright-green");
        wgPrint("", "ansi-green");
        wgPrint("TARGETS SELECTED:", "ansi-bright-red");
        wgPrint("", "ansi-green");
        wgPrint("  LAS VEGAS .................. PRIMARY", "ansi-bright-red");
        wgPrint("  SEATTLE .................... PRIMARY", "ansi-bright-red");
        wgPrint("  SAN FRANCISCO .............. SECONDARY", "ansi-red");
        wgPrint("", "ansi-green");

        setTimeout(() => {
          wgPrint("RUNNING SIMULATION...", "ansi-bright-green");
          wgPrint("", "ansi-green");
          let dots = 0;
          const sim = setInterval(() => {
            dots++;
            if (dots <= 5) {
              wgPrint(`SCENARIO ${dots}: ${["FIRST STRIKE", "COUNTERATTACK", "MUTUAL EXCHANGE", "ESCALATION", "AFTERMATH"][dots-1]}... RESULT: ${["ALL DEAD", "EVERYONE DEAD", "STILL DEAD", "VERY DEAD", "EXTINCTION"][dots-1]}`, "ansi-red");
            } else {
              clearInterval(sim);
              wgPrint("", "ansi-green");
              wgPrint("═══════════════════════════════════════════", "ansi-bright-green");
              wgPrint("", "ansi-green");
              wgPrint("A STRANGE GAME.", "ansi-bright-white");
              wgPrint("THE ONLY WINNING MOVE IS NOT TO PLAY.", "ansi-bright-white");
              wgPrint("", "ansi-green");
              wgPrint("═══════════════════════════════════════════", "ansi-bright-green");
              wgPrint("", "ansi-green");
              wgPrint("HOW ABOUT A NICE GAME OF BBS?", "ansi-bright-green");
              wgPrint("", "ansi-green");
              wgPrint("(Press ESC to return to Main Menu)", "ansi-bright-black");
              wgState = "done";
            }
          }, 600);
        }, 500);
      } else {
        wgPrint("", "ansi-green");
        wgPrint("A WISE CHOICE.", "ansi-bright-green");
        wgPrint("", "ansi-green");
        wgPrint("THE ONLY WINNING MOVE IS NOT TO PLAY.", "ansi-bright-white");
        wgPrint("", "ansi-green");
        wgPrint("HOW ABOUT A NICE GAME OF BBS?", "ansi-bright-green");
        wgPrint("(Press ESC to return to Main Menu)", "ansi-bright-black");
        wgState = "done";
      }
      return;
    }

    if (wgState === "done") {
      wgPrint(`\n> ${cmd}`, "ansi-bright-black");
      wgPrint("GAME OVER. PRESS ESC TO RETURN.", "ansi-green");
    }
  }

  wgInput?.addEventListener("keydown", (e) => {
    if (e.key === "Enter") {
      processWarGames(wgInput.value);
      wgInput.value = "";
    }
  });

  // ═══ Text Adventure Engine ═══
  type Room = {
    name: string;
    desc: string;
    exits: Record<string, string>;
    items?: string[];
    onEnter?: string;
  };

  const rooms: Record<string, Room> = {
    nau: {
      name: "Flagstaff, AZ — Northern Arizona University, 1984",
      desc: "You stand in a computer lab at NAU. Green CRTs flicker. A PDP-11 hums in the corner. Stacks of punch cards litter the desk. Your CS degree awaits.\n\nA recruiter's card reads: \"U.S. Navy — See the World.\"\nA dog-eared copy of Neuromancer sits on the shelf.",
      exits: { south: "navy", east: "apple_lab" },
      items: ["punch_cards", "recruiter_card"],
    },
    apple_lab: {
      name: "The Apple IIe Lab",
      desc: "Rows of Apple IIe computers glow with green phosphor. The ] prompt blinks patiently. Someone left a copy of Zork on the desk. A poster on the wall says \"THINK DIFFERENT\" — wait, that's not for another decade.\n\nA modem cradle sits next to the phone jack. 300 baud. The future.",
      exits: { west: "nau" },
      items: ["zork_disk", "modem_300baud"],
    },
    navy: {
      name: "NAS Point Mugu, Oxnard CA — P-3 Orion Squadron, 1987",
      desc: "The roar of turboprops fills the tarmac. You're a Petty Officer 2nd Class, Aviation ASW Operator. Your P-3 Orion is loaded for an Anti-Surface Warfare patrol over the Pacific.\n\nYou've tracked submarines by the sound of their screws. You've watched the sun set over the Pacific at 25,000 feet.\n\nA commission letter from the Air Force sits in your locker. The next chapter is calling.",
      exits: { north: "nau", east: "rome_labs" },
      items: ["flight_wings", "commission_letter"],
    },
    rome_labs: {
      name: "Rome Labs, Rome NY — USAF AI Division, 1991",
      desc: "1st Lieutenant LeBaron. You manage a $25M DARPA AI R&D portfolio. Teams from MIT, Carnegie Mellon, and Stanford send weekly reports.\n\nLisp Machines line the walls — Symbolics 3600s running Genera. A Sun workstation shows an early neural network visualization.\n\nA classified folder marked STRATCOM sits on your desk. The next mission awaits.",
      exits: { west: "navy", north: "stratcom" },
      items: ["darpa_badge", "lisp_manual", "symbolics_3600"],
    },
    stratcom: {
      name: "USSTRATCOM, Offutt AFB, Omaha NE — 1993",
      desc: "Captain LeBaron. You direct the Strategic Wargaming Systems — the real-world equivalent of the WOPR from WarGames. A 30-year-old mainframe that models nuclear deterrence scenarios for the nation.\n\nThe weight of the world hums in these racks. Every scenario you run has the same conclusion.\n\n\"A strange game. The only winning move is not to play.\"\n\nYour terminal contract is up. The private sector beckons.",
      exits: { south: "rome_labs", east: "andersen" },
      items: ["top_secret_clearance", "wargames_terminal"],
    },
    andersen: {
      name: "Andersen Consulting, Denver CO — 1996",
      desc: "Welcome to corporate consulting. Fortune 500 clients. Suits and PowerPoints. You're a Senior Solution Architect building enterprise systems.\n\nThe money is good. The PowerPoints are endless. The corner office has a view of the Rockies.\n\nA fax from Minneapolis reads: \"Build our EMEA org. From scratch. London.\"",
      exits: { west: "stratcom", north: "london" },
      items: ["business_cards"],
    },
    london: {
      name: "Callidus Software, London UK — 2001",
      desc: "You've crossed the Atlantic. Head of Services, EMEA. A startup in the nascent SPM (Sales Performance Management) space.\n\nSGI Indigo workstations in the office — because some habits die hard. The City buzzes outside. You're building something from nothing in a foreign land.\n\nAn idea takes root: what if you started your own firm?",
      exits: { south: "andersen", east: "austin" },
      items: ["british_passport_stamp", "sgi_indigo"],
    },
    austin: {
      name: "OpenSymmetry HQ, Austin TX — 2009",
      desc: "YOU DID IT. Founder & CEO. OpenSymmetry grows to a $30M professional services firm — the largest independent SPM consultancy in the world.\n\nThe team celebrates another record quarter. The Inc. 500 award sits on your desk.\n\nBut there's always the next chapter...",
      exits: { west: "london", north: "scottsdale" },
      items: ["company_keys", "inc_500_award"],
    },
    scottsdale: {
      name: "ŒXITS LLC / AI Code Rally, Scottsdale AZ — Present Day",
      desc: "The journey led here — Founder of ŒXITS, building the AI Code Rally platform. Enterprise AI governance. 22 Go microservices. Purple and orange terminal themes.\n\nEverything you learned — Navy discipline, DARPA AI research, the real WOPR, global consulting, company building — converges in this desert office.\n\nThe BBS terminal blinks. Another caller connects. The modem LEDs dance.\n\nThe machines changed. The mission didn't.\n\n*** YOU HAVE COMPLETED CAREER QUEST ***\n*** Total items collected: check your inventory! ***",
      exits: { south: "austin" },
      items: ["ai_platform"],
      onEnter: "The wind carries the scent of desert sage. You've come full circle.",
    },
  };

  let currentRoom = "nau";
  let inventory: string[] = [];
  const outputEl = document.getElementById("adventure-output")!;
  const inputEl = document.getElementById("adventure-input") as HTMLInputElement;

  function adventurePrint(text: string, color = "ansi-white"): void {
    const div = document.createElement("div");
    div.style.marginBottom = "6px";
    div.style.whiteSpace = "pre-wrap";
    div.innerHTML = `<span class="${color}">${text}</span>`;
    outputEl.appendChild(div);
    outputEl.scrollTop = outputEl.scrollHeight;
  }

  function describeRoom(): void {
    const room = rooms[currentRoom];
    adventurePrint(`\n═══ ${room.name} ═══`, "tf-orange");
    adventurePrint(room.desc);
    if (room.onEnter) adventurePrint(room.onEnter, "tf-purple-bright");
    const exits = Object.keys(room.exits);
    adventurePrint(`\nExits: ${exits.join(", ")}`, "ansi-green");
    if (room.items?.length) {
      const uncollected = room.items.filter((i) => !inventory.includes(i));
      if (uncollected.length) {
        adventurePrint(`You see: ${uncollected.map((i) => i.replace(/_/g, " ")).join(", ")}`, "tf-orange-bright");
      }
    }
  }

  function processCommand(cmd: string): void {
    const c = cmd.trim().toLowerCase();
    adventurePrint(`\n> ${cmd}`, "ansi-bright-black");

    if (!c) return;

    if (c === "help") {
      adventurePrint("Commands: look, north/south/east/west, take [item], inventory, quit", "tf-purple-bright");
      adventurePrint("Pro tip: Collect items in each location for a complete dossier.", "ansi-bright-black");
      return;
    }
    if (c === "look" || c === "l") { describeRoom(); return; }
    if (c === "inventory" || c === "i") {
      if (!inventory.length) adventurePrint("Your pockets are empty. Every journey starts light.");
      else {
        adventurePrint(`Carrying (${inventory.length} items):`, "tf-orange-bright");
        inventory.forEach((i) => adventurePrint(`  ► ${i.replace(/_/g, " ")}`, "tf-purple-bright"));
      }
      return;
    }
    if (c === "quit" || c === "q") { goBack(); return; }

    const room = rooms[currentRoom];
    if (room.exits[c]) {
      currentRoom = room.exits[c];
      describeRoom();
      return;
    }

    if (c.startsWith("take ") || c.startsWith("get ")) {
      const itemName = c.split(" ").slice(1).join("_");
      const room = rooms[currentRoom];
      if (room.items?.includes(itemName) && !inventory.includes(itemName)) {
        inventory.push(itemName);
        adventurePrint(`Taken: ${itemName.replace(/_/g, " ")}`, "tf-orange");
        if (inventory.length === 1) adventurePrint("First artifact collected. Keep exploring.", "ansi-bright-black");
        if (inventory.length === 5) adventurePrint("Halfway there. You're building quite the dossier.", "ansi-bright-black");
        if (inventory.length >= 10) adventurePrint("Impressive collection. You've traced the full career path.", "tf-gold");
      } else {
        adventurePrint("Nothing to take here.");
      }
      return;
    }

    adventurePrint("I don't understand that command. Type 'help' for options.", "ansi-bright-black");
  }

  document.addEventListener("boot:complete", () => {
    // Pre-render first room when adventure is first opened
  });

  const observer = new MutationObserver(() => {
    const adventureScreen = document.getElementById("bbs-screen-adventure");
    if (adventureScreen?.classList.contains("bbs-active") && outputEl.children.length === 0) {
      describeRoom();
    }
  });
  observer.observe(document.getElementById("bbs-content")!, { subtree: true, attributes: true, attributeFilter: ["class"] });

  inputEl?.addEventListener("keydown", (e) => {
    if (e.key === "Enter") {
      processCommand(inputEl.value);
      inputEl.value = "";
    }
  });
</script>
