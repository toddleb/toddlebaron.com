---
// T-NET BBS — Main Terminal
// "Personal Network of Todd LeBaron"
---

<div id="bbs-content">
  <!-- ═══ Main Menu Screen ═══ -->
  <section id="bbs-screen-menu" class="bbs-screen bbs-active">
    <!-- T-NET Banner (inside monitor screen) -->
    <pre class="bbs-banner"><span class="tf-orange">████████╗   ███╗   ██╗ ███████╗ ████████╗</span>
<span class="tf-orange">╚══██╔══╝   ████╗  ██║ ██╔════╝ ╚══██╔══╝</span>
<span class="tf-orange">   ██║  ═══ ██╔██╗ ██║ █████╗      ██║</span>
<span class="tf-orange">   ██║      ██║╚██╗██║ ██╔══╝      ██║</span>
<span class="tf-orange">   ██║      ██║ ╚████║ ███████╗    ██║</span>
<span class="tf-orange">   ╚═╝      ╚═╝  ╚═══╝ ╚══════╝    ╚═╝</span>

  <span class="tf-purple-bright">Personal Network of Todd LeBaron</span>
  <span class="ansi-bright-black">Est. 1984 · Scottsdale, AZ · Node 1</span></pre>

    <div class="bbs-menu">
      <div class="bbs-menu-border">
        <span class="tf-purple">┌─── </span><span class="tf-orange">MAIN MENU</span><span class="tf-purple"> ──────────────────────────────────────────────┐</span>
      </div>
      <div class="bbs-menu-items">
        <div class="bbs-menu-row">
          <span class="bbs-menu-item" data-bbs-nav="about">
            <span class="tf-orange">[A]</span> <span class="ansi-bright-white">About the SysOp</span>
          </span>
          <span class="bbs-menu-item" data-bbs-nav="blog">
            <span class="tf-orange">[B]</span> <span class="ansi-bright-white">Bulletins</span>
          </span>
        </div>
        <div class="bbs-menu-row">
          <span class="bbs-menu-item" data-bbs-nav="computing-history">
            <span class="tf-orange">[H]</span> <span class="ansi-bright-white">Computing History</span>
          </span>
          <span class="bbs-menu-item" data-bbs-nav="contact">
            <span class="tf-orange">[M]</span> <span class="ansi-bright-white">Mail SysOp</span>
          </span>
        </div>
        <div class="bbs-menu-row">
          <span class="bbs-menu-item" data-bbs-nav="resume">
            <span class="tf-orange">[R]</span> <span class="ansi-bright-white">Résumé / Dossier</span>
          </span>
          <span class="bbs-menu-item" data-bbs-nav="goodbye">
            <span class="tf-orange">[G]</span> <span class="ansi-bright-white">Goodbye (Logoff)</span>
          </span>
        </div>
      </div>
      <div class="bbs-menu-border">
        <span class="tf-purple">└──────────────────────────────────────────────────────────────────┘</span>
      </div>
    </div>

    <div class="bbs-prompt">
      <span class="tf-purple-bright">Command: </span><span class="bbs-cursor">█</span>
    </div>
  </section>

  <!-- ═══ Content screens injected from page slot ═══ -->
  <slot />

  <!-- ═══ Logoff Overlay ═══ -->
  <div id="bbs-logoff" class="bbs-logoff">
    <div class="bbs-logoff-text">
      <div class="tf-orange">NO CARRIER</div>
      <div class="ansi-bright-black">Thank you for calling T-NET BBS.</div>
      <div class="ansi-bright-black">The SysOp appreciates your visit.</div>
      <div style="margin-top:16px;">
        <span class="tf-purple-bright" style="cursor:pointer" id="bbs-reconnect">[ Reconnect ]</span>
      </div>
    </div>
  </div>
</div>

<script>
  // ─── BBS Screen Navigation ───
  const keyMap: Record<string, string> = {
    a: "about",
    b: "blog",
    h: "computing-history",
    m: "contact",
    r: "resume",
    g: "goodbye",
  };

  function showScreen(id: string): void {
    document.querySelectorAll(".bbs-screen").forEach((s) => s.classList.remove("bbs-active"));
    const target = document.getElementById(`bbs-screen-${id}`);
    if (target) {
      target.classList.add("bbs-active");
      // Scroll the screen content area to top
      const screenContent = document.querySelector(".hw-screen-content");
      if (screenContent) screenContent.scrollTop = 0;
    }
  }

  // Click-based nav
  document.querySelectorAll<HTMLElement>("[data-bbs-nav]").forEach((el) => {
    el.addEventListener("click", () => {
      const target = el.dataset.bbsNav!;
      if (target === "goodbye") {
        triggerLogoff();
      } else {
        showScreen(target);
      }
    });
  });

  // Back buttons
  document.querySelectorAll("[data-bbs-back]").forEach((el) => {
    el.addEventListener("click", () => showScreen("menu"));
  });

  // Keyboard nav
  document.addEventListener("keydown", (e: KeyboardEvent) => {
    if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;

    if (e.key === "Escape") {
      showScreen("menu");
      return;
    }

    const menuVisible = document.getElementById("bbs-screen-menu")?.classList.contains("bbs-active");
    if (menuVisible) {
      const screen = keyMap[e.key.toLowerCase()];
      if (screen) {
        if (screen === "goodbye") {
          triggerLogoff();
        } else {
          showScreen(screen);
        }
      }
    }
  });

  // Logoff
  function triggerLogoff(): void {
    if (typeof (window as any).__modemDisconnect === "function") {
      (window as any).__modemDisconnect();
    }
    const logoff = document.getElementById("bbs-logoff");
    if (logoff) logoff.classList.add("active");
  }

  // Reconnect
  document.getElementById("bbs-reconnect")?.addEventListener("click", () => {
    const logoff = document.getElementById("bbs-logoff");
    if (logoff) logoff.classList.remove("active");
    showScreen("menu");
  });
</script>
