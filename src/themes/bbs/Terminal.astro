---
// T-NET BBS — Main Terminal
// "Personal Network of Todd LeBaron"
---

<div id="bbs-content">
  <!-- ═══ Main Menu Screen ═══ -->
  <section id="bbs-screen-menu" class="bbs-screen bbs-active">
    <!-- T-NET Title (matches splash aesthetic) -->
    <div class="bbs-hero">
      <div class="bbs-hero-title">T – N E T</div>
      <div class="bbs-hero-sub">B  B  S</div>
      <div class="bbs-gradient-line"></div>
      <div class="bbs-hero-tagline">PERSONAL NETWORK OF TODD LEBARON</div>
      <div class="bbs-hero-meta">Est. 1984 · Scottsdale, AZ · Node 1</div>
    </div>

    <div class="bbs-menu">
      <div class="bbs-menu-label"><span class="tf-orange">MAIN MENU</span></div>
      <div class="bbs-gradient-line"></div>
      <div class="bbs-menu-items">
        <div class="bbs-menu-row">
          <span class="bbs-menu-item" data-bbs-nav="about">
            <span class="bbs-key">A</span> <span class="bbs-label">About the SysOp</span>
          </span>
          <span class="bbs-menu-item" data-bbs-nav="blog">
            <span class="bbs-key">B</span> <span class="bbs-label">Bulletins</span>
          </span>
        </div>
        <div class="bbs-menu-row">
          <span class="bbs-menu-item" data-bbs-nav="computing-history">
            <span class="bbs-key">H</span> <span class="bbs-label">Computing History</span>
          </span>
          <span class="bbs-menu-item" data-bbs-nav="contact">
            <span class="bbs-key">M</span> <span class="bbs-label">Mail SysOp</span>
          </span>
        </div>
        <div class="bbs-menu-row">
          <span class="bbs-menu-item" data-bbs-nav="resume">
            <span class="bbs-key">R</span> <span class="bbs-label">Résumé / Dossier</span>
          </span>
          <span class="bbs-menu-item" data-bbs-nav="goodbye">
            <span class="bbs-key">G</span> <span class="bbs-label">Goodbye (Logoff)</span>
          </span>
        </div>
        <div class="bbs-menu-row">
          <span class="bbs-menu-item" id="bbs-reboot">
            <span class="bbs-key">!</span> <span class="bbs-label">Reboot System</span>
          </span>
        </div>
      </div>
      <div class="bbs-gradient-line"></div>
    </div>

    <div class="bbs-prompt">
      <span class="tf-purple-bright">Command: </span><span class="bbs-cursor">█</span>
    </div>

    <div class="bbs-status-line">
      <span class="ansi-bright-black">14400 baud</span>
      <span class="ansi-bright-black">·</span>
      <span class="ansi-bright-black">ANSI color</span>
      <span class="ansi-bright-black">·</span>
      <span class="ansi-bright-black">Caller #48,291</span>
      <span class="ansi-bright-black">·</span>
      <span class="tf-gold">3 new messages</span>
    </div>
  </section>

  <!-- ═══ Content screens injected from page slot ═══ -->
  <slot />

  <!-- ═══ Logoff Overlay ═══ -->
  <div id="bbs-logoff" class="bbs-logoff">
    <div class="bbs-logoff-text">
      <div class="tf-orange">NO CARRIER</div>
      <div class="ansi-bright-black">Thank you for calling T-NET BBS.</div>
      <div class="ansi-bright-black">The SysOp appreciates your visit.</div>
      <div style="margin-top:16px;">
        <span class="tf-purple-bright" style="cursor:pointer" id="bbs-reconnect">[ Reconnect ]</span>
      </div>
    </div>
  </div>
</div>

<script>
  // ─── BBS Screen Navigation ───
  const keyMap: Record<string, string> = {
    a: "about",
    b: "blog",
    h: "computing-history",
    m: "contact",
    r: "resume",
    g: "goodbye",
    "!": "reboot",
  };

  function showScreen(id: string): void {
    document.querySelectorAll(".bbs-screen").forEach((s) => s.classList.remove("bbs-active"));
    const target = document.getElementById(`bbs-screen-${id}`);
    if (target) {
      target.classList.add("bbs-active");
      document.dispatchEvent(new CustomEvent("bbs:page-change", { detail: { screen: id } }));
      document.dispatchEvent(new CustomEvent("bbs:content-rendered"));
      // Scroll the screen content area to top
      const screenContent = document.querySelector(".hw-screen-content");
      if (screenContent) screenContent.scrollTop = 0;
    }
  }

  // Click-based nav
  document.querySelectorAll<HTMLElement>("[data-bbs-nav]").forEach((el) => {
    el.addEventListener("click", () => {
      const target = el.dataset.bbsNav!;
      if (target === "goodbye") {
        triggerLogoff();
      } else {
        showScreen(target);
      }
    });
  });

  // Back buttons
  document.querySelectorAll("[data-bbs-back]").forEach((el) => {
    el.addEventListener("click", () => showScreen("menu"));
  });

  // Keyboard nav
  document.addEventListener("keydown", (e: KeyboardEvent) => {
    if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;

    if (e.key === "Escape") {
      showScreen("menu");
      return;
    }

    const menuVisible = document.getElementById("bbs-screen-menu")?.classList.contains("bbs-active");
    if (menuVisible) {
      const screen = keyMap[e.key.toLowerCase()];
      if (screen) {
        if (screen === "goodbye") {
          triggerLogoff();
        } else if (screen === "reboot") {
          triggerReboot();
        } else {
          showScreen(screen);
        }
      }
    }
  });

  // Reboot — replay boot sequence in-place (no reload = keeps audio activation)
  function triggerReboot(): void {
    document.cookie = "toddlebaron-visited=;path=/;max-age=0";
    showScreen("menu");
    if (typeof (window as any).__rebootBBS === "function") {
      (window as any).__rebootBBS();
    }
  }

  document.getElementById("bbs-reboot")?.addEventListener("click", triggerReboot);

  // Logoff
  function triggerLogoff(): void {
    if (typeof (window as any).__modemDisconnect === "function") {
      (window as any).__modemDisconnect();
    }
    const logoff = document.getElementById("bbs-logoff");
    if (logoff) logoff.classList.add("active");
  }

  // Reconnect
  document.getElementById("bbs-reconnect")?.addEventListener("click", () => {
    const logoff = document.getElementById("bbs-logoff");
    if (logoff) logoff.classList.remove("active");
    showScreen("menu");
  });
</script>
