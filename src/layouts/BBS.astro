---
// src/layouts/BBS.astro — T-NET BBS
// Screen: CRT terminal at top, physical modem hardware at bottom
import SEOHead from "../components/SEOHead.astro";
import Modem from "../themes/bbs/Modem.astro";
import "../themes/bbs/theme.css";
export interface Props {
  title?: string;
  description?: string;
}
const { title = "T-NET BBS — Todd LeBaron", description = "Personal network of Todd LeBaron. Est. 1984." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <SEOHead title={title} description={description} />
    <slot name="head" />
  </head>
  <body class="bbs-body">
    <div class="bbs-crt">
      <div class="bbs-scanlines"></div>
      <div class="bbs-terminal" id="bbs-terminal">
        <slot />
      </div>
    </div>
    <Modem />
  </body>
</html>
