---
// src/layouts/BBS.astro — T-NET BBS
// Desk layout: Monitor (screen = all content) → Computer → Modem
import SEOHead from "../components/SEOHead.astro";
import Modem from "../themes/bbs/Modem.astro";
import AlbumPlayer from "../themes/bbs/AlbumPlayer.astro";
import RainWindow from "../themes/bbs/RainWindow.astro";
import DeskLamp from "../themes/bbs/DeskLamp.astro";
import DeskPlant from "../themes/bbs/DeskPlant.astro";
// WallClock removed from desk scene
import Scarab from "../themes/bbs/Scarab.astro";
import Snow from "../components/Snow.astro";
import "../themes/bbs/theme.css";
export interface Props {
  title?: string;
  description?: string;
}
const { title = "T-NET BBS — Todd LeBaron", description = "Personal network of Todd LeBaron. Est. 1984." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <SEOHead title={title} description={description} />
    <slot name="head" />
  </head>
  <body class="bbs-body">
    <!-- Room -->
    <div class="room">
      <!-- Wall -->
      <RainWindow />
      <div class="wall">
        <!-- Album shelf -->
        <div class="album-shelf">
          <div class="album-cover" data-album="chicago-17"><img src="/albums/chicago.jpg" alt="Chicago 17" /></div>
          <div class="album-cover" data-album="papa-roach-paramour"><img src="/albums/papa-roach.jpg" alt="Papa Roach - The Paramour Sessions" /></div>
          <div class="album-cover" data-album="silversun-pickups-swoon"><img src="/albums/silversun-pickups-swoon.jpg" alt="Silversun Pickups - Swoon" /></div>
          <div class="album-cover" data-album="silversun-pickups-physical-thrills"><img src="/albums/silversun-pickups-physical-thrills.jpeg" alt="Silversun Pickups - Physical Thrills" /></div>
          <div class="album-cover" data-album="linkin-park-hybrid-theory"><img src="/albums/linkin-park.jpg" alt="Linkin Park - Hybrid Theory" /></div>
          <div class="album-cover" data-album="shinedown"><img src="/albums/shinedown.jpg" alt="Shinedown - Leave a Whisper" /></div>
          <div class="album-cover" data-album="halestorm"><img src="/albums/halestorm.png" alt="Halestorm" /></div>
          <div class="album-cover" data-album="evanescence"><img src="/albums/evanescence.png" alt="Evanescence - The Bitter Truth" /></div>
          <div class="album-cover" data-album="godsmack"><img src="/albums/godsmack.png" alt="Godsmack - Lighting Up the Sky" /></div>
          <div class="album-cover" data-album="fair-to-midland"><img src="/albums/fair-to-midland.jpg" alt="Fair to Midland - Fables from a Mayfly" /></div>
          <div class="album-cover" data-album="breaking-benjamin"><img src="/albums/breaking-benjamin.jpg" alt="Breaking Benjamin - Phobia" /></div>
          <div class="album-cover" data-album="kansas-leftoverture"><img src="/albums/kansas.jpg" alt="Kansas - Leftoverture" /></div>
        </div>
        <!-- B-wing model on shelf -->
        <div class="shelf-model">
          <img src="/bwing.png" alt="B-wing starfighter model" />
        </div>
      </div>

      <!-- Chair rail molding between wall and brick -->
      <div class="chair-rail"></div>

      <!-- Room darkness overlay (toggled by lamp) -->
      <div class="room-darkness" id="room-darkness"></div>
      <!-- Desk Lamp (night) / Plant (day) — room-level so never clipped -->
      <DeskLamp />
      <DeskPlant />
      <!-- Desk -->
      <div class="desk">
        <!-- Hardware stack -->
        <div class="hw-stack">
          <!-- Monitor -->
          <div class="hw-monitor">
            <div class="hw-monitor-body">
              <div class="hw-screen" id="bbs-terminal">
                <div class="bbs-scanlines"></div>
                <div class="hw-screen-content">
                  <slot />
                </div>
                <div class="hw-screen-statusbar">
                  <span id="screen-baud" class="tf-purple-bright">14400</span>
                  <span class="ansi-bright-black">BAUD</span>
                  <span class="screen-status-sep">·</span>
                  <span class="ansi-bright-black">ANSI</span>
                  <span class="screen-status-sep">·</span>
                  <span class="ansi-bright-black">V.42bis</span>
                </div>
              </div>
              <div class="hw-monitor-chin">
                <span class="hw-brand-label">Apple XXVIe</span>
                <div class="hw-power-indicator hw-power-btn" id="monitor-power">
                  <span class="hw-power-led"></span>
                  <span class="hw-power-label">POWER</span>
                </div>
              </div>
            </div>
            <div class="hw-felt-feet">
              <span class="felt-foot"></span>
              <span class="felt-foot"></span>
              <span class="felt-foot"></span>
              <span class="felt-foot"></span>
            </div>
          </div>
          <!-- Computer (on top of modem) -->
          <div class="hw-computer">
            <div class="hw-computer-body">
              <div class="hw-computer-brand">
                <span class="hw-brand-label">Apple XXVIe</span>
              </div>
              <!-- LED ticker screen -->
              <div class="hw-led-screen" id="hw-led-screen">
                <div class="hw-led-content" id="hw-led-content">
                  <span class="hw-led-text" id="hw-led-text">T-NET BBS · EST. 1984 · SCOTTSDALE, AZ</span>
                </div>
              </div>
              <AlbumPlayer />
              <div class="hw-computer-ports">
                <span class="hw-port"></span>
                <span class="hw-port"></span>
                <span class="hw-port hw-port-wide"></span>
              </div>
              <div class="hw-power-indicator hw-power-btn" id="computer-power">
                <span class="hw-power-led"></span>
                <span class="hw-power-label">POWER</span>
              </div>
            </div>
            <div class="hw-felt-feet">
              <span class="felt-foot"></span>
              <span class="felt-foot"></span>
              <span class="felt-foot"></span>
              <span class="felt-foot"></span>
            </div>
          </div>
          <!-- Modem (bottom of stack) -->
          <div class="hw-modem-wrap">
            <Modem />
            <div class="hw-felt-feet">
              <span class="felt-foot"></span>
              <span class="felt-foot"></span>
              <span class="felt-foot"></span>
              <span class="felt-foot"></span>
            </div>
          </div>
        </div>
        <!-- Yoo-hoo bottle (draggable) -->
        <div class="desk-yoohoo draggable-desk-item" id="desk-yoohoo">
          <img src="/yoohoo.png" alt="Yoo-hoo chocolate drink" draggable="false" />
        </div>
      </div>

      <!-- Desk surface -->
      <div class="desk-surface">
        <div class="crt-desk-glow"></div>
        <div class="desk-edge"></div>
      </div>
    </div>
    <Scarab />
    <Snow />
  </body>
</html>

<script>
  // Draggable desk items
  document.querySelectorAll<HTMLElement>(".draggable-desk-item").forEach((el) => {
    let dragging = false;
    let offsetX = 0;
    let offsetY = 0;

    el.addEventListener("mousedown", (e) => {
      dragging = true;
      const rect = el.getBoundingClientRect();
      offsetX = e.clientX - rect.left;
      offsetY = e.clientY - rect.top;
      el.style.zIndex = "50";
      el.style.cursor = "grabbing";
      e.preventDefault();
    });

    document.addEventListener("mousemove", (e) => {
      if (!dragging) return;
      const parent = el.offsetParent as HTMLElement;
      if (!parent) return;
      const parentRect = parent.getBoundingClientRect();
      el.style.left = `${e.clientX - parentRect.left - offsetX}px`;
      el.style.top = `${e.clientY - parentRect.top - offsetY}px`;
      el.style.right = "auto";
      el.style.bottom = "auto";
    });

    document.addEventListener("mouseup", () => {
      if (!dragging) return;
      dragging = false;
      el.style.cursor = "grab";
    });
  });
</script>

<script>
  // B-wing fly-away with Star Wars ship sound
  const bwing = document.querySelector<HTMLElement>('.shelf-model');
  if (bwing) {
    let flown = false;
    bwing.addEventListener('click', () => {
      if (flown) return;
      flown = true;

      // B-wing flyby sound (fan recreation by Star Wars SFX Archive)
      const sfx = new Audio('/sounds/bwing-flyby.mp3');
      sfx.volume = 1.0;
      sfx.play().catch(() => {});

      // Trigger CSS animation
      bwing.classList.add('flying');

      // Return after animation
      setTimeout(() => {
        bwing.classList.remove('flying');
        flown = false;
      }, 9000);
    });
  }
</script>

<script>
  // Lamp pull chain toggle
  const chain = document.getElementById('lamp-pull-chain');
  const lamp = chain?.closest('.desk-lamp') as HTMLElement | null;
  const room = document.querySelector('.room') as HTMLElement | null;
  const darkness = document.getElementById('room-darkness');
  if (chain && lamp && room && darkness) {
    chain.addEventListener('click', () => {
      const isOff = lamp.classList.toggle('lamp-off');
      room.classList.toggle('lamp-off', isOff);
      darkness.classList.toggle('active', isOff);
    });
  }
</script>

<script>
  // ─── Power Button Controls ───
  const ctx = new AudioContext();

  // Mac startup chime (C major chord: C4, E4, G4, C5)
  function playStartupChime() {
    const now = ctx.currentTime;
    const freqs = [261.6, 329.6, 392.0, 523.3];
    freqs.forEach((f) => {
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.type = 'sine';
      osc.frequency.value = f;
      gain.gain.setValueAtTime(0.12, now);
      gain.gain.exponentialRampToValueAtTime(0.001, now + 2.5);
      osc.connect(gain).connect(ctx.destination);
      osc.start(now);
      osc.stop(now + 2.5);
    });
  }

  // Shutdown chime (descending: G4, E4, C4)
  function playShutdownChime() {
    const now = ctx.currentTime;
    const notes = [
      { freq: 392.0, start: 0, dur: 0.3 },
      { freq: 329.6, start: 0.15, dur: 0.3 },
      { freq: 261.6, start: 0.3, dur: 0.6 },
    ];
    notes.forEach(({ freq, start, dur }) => {
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.type = 'sine';
      osc.frequency.value = freq;
      gain.gain.setValueAtTime(0.1, now + start);
      gain.gain.exponentialRampToValueAtTime(0.001, now + start + dur);
      osc.connect(gain).connect(ctx.destination);
      osc.start(now + start);
      osc.stop(now + start + dur);
    });
  }

  // Modem disconnect screech
  function playModemDisconnect() {
    const now = ctx.currentTime;
    const osc = ctx.createOscillator();
    const gain = ctx.createGain();
    osc.type = 'sawtooth';
    osc.frequency.setValueAtTime(2400, now);
    osc.frequency.exponentialRampToValueAtTime(300, now + 0.4);
    gain.gain.setValueAtTime(0.08, now);
    gain.gain.exponentialRampToValueAtTime(0.001, now + 0.5);
    osc.connect(gain).connect(ctx.destination);
    osc.start(now);
    osc.stop(now + 0.5);
  }

  // Modem reconnect dial tone
  function playModemReconnect() {
    const now = ctx.currentTime;
    // Dial tone: two sine waves
    [350, 440].forEach((f) => {
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.type = 'sine';
      osc.frequency.value = f;
      gain.gain.setValueAtTime(0.06, now);
      gain.gain.setValueAtTime(0.06, now + 0.3);
      gain.gain.exponentialRampToValueAtTime(0.001, now + 0.4);
      osc.connect(gain).connect(ctx.destination);
      osc.start(now);
      osc.stop(now + 0.4);
    });
    // Then a quick handshake screech
    setTimeout(() => {
      const n = ctx.currentTime;
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.type = 'square';
      osc.frequency.setValueAtTime(1200, n);
      osc.frequency.linearRampToValueAtTime(2400, n + 0.3);
      gain.gain.setValueAtTime(0.04, n);
      gain.gain.exponentialRampToValueAtTime(0.001, n + 0.4);
      osc.connect(gain).connect(ctx.destination);
      osc.start(n);
      osc.stop(n + 0.4);
    }, 500);
  }

  // ── Monitor power ──
  const monitorPower = document.getElementById('monitor-power');
  const monitor = document.querySelector('.hw-monitor') as HTMLElement | null;
  if (monitorPower && monitor) {
    monitorPower.addEventListener('click', () => {
      if (monitor.classList.contains('powered-off')) {
        // Power on
        monitor.classList.remove('powered-off');
        monitor.classList.add('powering-on');
        setTimeout(() => monitor.classList.remove('powering-on'), 700);
      } else {
        // Power off — CRT phosphor dot
        monitor.classList.add('powered-off');
      }
    });
  }

  // ── Computer power ──
  const computerPower = document.getElementById('computer-power');
  const computer = document.querySelector('.hw-computer') as HTMLElement | null;
  if (computerPower && computer) {
    computerPower.addEventListener('click', () => {
      if (computer.classList.contains('powered-off')) {
        computer.classList.remove('powered-off');
        playStartupChime();
      } else {
        computer.classList.add('powered-off');
        playShutdownChime();
      }
    });
  }

  // ── Modem power ──
  const modemPower = document.getElementById('modem-power');
  const modemWrap = document.querySelector('.hw-modem-wrap') as HTMLElement | null;
  if (modemPower && modemWrap) {
    modemPower.addEventListener('click', () => {
      if (modemWrap.classList.contains('powered-off')) {
        modemWrap.classList.remove('powered-off');
        playModemReconnect();
      } else {
        modemWrap.classList.add('powered-off');
        playModemDisconnect();
      }
    });
  }
</script>

<script>
  import { initTimeOfDay } from "../engine/time-of-day";
  import { startAmbient } from "../engine/ambient";
  import { initTypingSounds, playMenuBeep, playHDDChatter } from "../engine/typing-sounds";

  initTimeOfDay();

  document.addEventListener("boot:complete", () => {
    startAmbient("bbs");
    initTypingSounds("bbs");

    // UI sounds: menu beep
    document.querySelectorAll(".bbs-menu-item").forEach((el) => {
      el.addEventListener("click", playMenuBeep);
    });

    // UI sounds: HDD chatter on page change
    document.addEventListener("bbs:page-change", playHDDChatter);

    // Idle timer (2 minutes)
    let idleTimer: ReturnType<typeof setTimeout>;
    function resetIdle() {
      document.body.classList.remove("idle-active");
      clearTimeout(idleTimer);
      idleTimer = setTimeout(() => document.body.classList.add("idle-active"), 120_000);
    }
    resetIdle();
    document.addEventListener("mousemove", resetIdle);
    document.addEventListener("keydown", resetIdle);
    document.addEventListener("click", resetIdle);
    document.addEventListener("touchstart", resetIdle);
  });
</script>
