---
// src/layouts/BBS.astro — T-NET BBS
// Desk layout: Monitor (screen = all content) → Computer → Modem
import SEOHead from "../components/SEOHead.astro";
import Modem from "../themes/bbs/Modem.astro";
import "../themes/bbs/theme.css";
export interface Props {
  title?: string;
  description?: string;
}
const { title = "T-NET BBS — Todd LeBaron", description = "Personal network of Todd LeBaron. Est. 1984." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <SEOHead title={title} description={description} />
    <slot name="head" />
  </head>
  <body class="bbs-body">
    <!-- Room -->
    <div class="room">
      <!-- Wall -->
      <div class="wall">
        <!-- Album shelf -->
        <div class="album-shelf">
          <div class="album-cover"><img src="/albums/chicago.jpg" alt="Chicago 17" /></div>
          <div class="album-cover"><img src="/albums/papa-roach.jpg" alt="Papa Roach - The Paramour Sessions" /></div>
          <div class="album-cover"><img src="/albums/silversun-pickups.jpeg" alt="Silversun Pickups - Physical Thrills" /></div>
          <div class="album-cover"><img src="/albums/linkin-park.jpg" alt="Linkin Park - Hybrid Theory" /></div>
          <div class="album-cover"><img src="/albums/shinedown.jpg" alt="Shinedown - The Sound of Madness" /></div>
          <div class="album-cover"><img src="/albums/halestorm.png" alt="Halestorm" /></div>
          <div class="album-cover"><img src="/albums/evanescence.png" alt="Evanescence - The Bitter Truth" /></div>
          <div class="album-cover"><img src="/albums/godsmack.png" alt="Godsmack - Lighting Up the Sky" /></div>
          <div class="album-cover"><img src="/albums/fair-to-midland.jpg" alt="Fair to Midland - Fables from a Mayfly" /></div>
          <div class="album-cover"><img src="/albums/breaking-benjamin.jpg" alt="Breaking Benjamin - Phobia" /></div>
          <!-- B-wing model -->
          <div class="shelf-model">
            <img src="/bwing.png" alt="B-wing starfighter model" />
          </div>
        </div>
      </div>

      <!-- Desk -->
      <div class="desk">
        <!-- Hardware stack -->
        <div class="hw-stack">
          <!-- Monitor -->
          <div class="hw-monitor">
            <div class="hw-monitor-body">
              <div class="hw-screen" id="bbs-terminal">
                <div class="bbs-scanlines"></div>
                <div class="hw-screen-content">
                  <slot />
                </div>
                <div class="hw-screen-statusbar">
                  <span id="screen-baud" class="tf-purple-bright">14400</span>
                  <span class="ansi-bright-black">BAUD</span>
                  <span class="screen-status-sep">·</span>
                  <span class="ansi-bright-black">ANSI</span>
                  <span class="screen-status-sep">·</span>
                  <span class="ansi-bright-black">V.42bis</span>
                </div>
              </div>
              <div class="hw-monitor-chin">
                <span class="hw-brand-label">Apple XXVIe</span>
                <div class="hw-power-indicator">
                  <span class="hw-power-led"></span>
                  <span class="hw-power-label">POWER</span>
                </div>
              </div>
            </div>
            <div class="hw-felt-feet">
              <span class="felt-foot"></span>
              <span class="felt-foot"></span>
              <span class="felt-foot"></span>
              <span class="felt-foot"></span>
            </div>
          </div>
          <!-- Computer (on top of modem) -->
          <div class="hw-computer">
            <div class="hw-computer-body">
              <div class="hw-computer-brand">
                <span class="hw-brand-label">Apple XXVIe</span>
              </div>
              <div class="hw-computer-ports">
                <span class="hw-port"></span>
                <span class="hw-port"></span>
                <span class="hw-port hw-port-wide"></span>
              </div>
              <div class="hw-power-indicator">
                <span class="hw-power-led"></span>
                <span class="hw-power-label">POWER</span>
              </div>
            </div>
            <div class="hw-felt-feet">
              <span class="felt-foot"></span>
              <span class="felt-foot"></span>
              <span class="felt-foot"></span>
              <span class="felt-foot"></span>
            </div>
          </div>
          <!-- Modem (bottom of stack) -->
          <div class="hw-modem-wrap">
            <Modem />
            <div class="hw-felt-feet">
              <span class="felt-foot"></span>
              <span class="felt-foot"></span>
              <span class="felt-foot"></span>
              <span class="felt-foot"></span>
            </div>
          </div>
        </div>
        <!-- Yoo-hoo bottle -->
        <div class="desk-yoohoo">
          <img src="/yoohoo.png" alt="Yoo-hoo chocolate drink" />
        </div>
      </div>

      <!-- Desk surface -->
      <div class="desk-surface">
        <div class="desk-edge"></div>
      </div>
    </div>
  </body>
</html>
