---
// src/components/EraPickerOverlay.astro
// Rich era picker with CSS-art preview cards
---

<div id="era-picker" class="era-picker-overlay" style="display:none" role="dialog" aria-label="Choose Era">
  <div class="era-picker-content">
    <div class="era-picker-header">
      <div>
        <h2 class="era-picker-title">Choose Your Era &mdash; A Journey Through Computing</h2>
        <p class="era-picker-subtitle">Each era recreates the desktop experience of that machine</p>
      </div>
      <button id="era-picker-close" class="era-close-btn" aria-label="Close">
        <span class="era-close-x">&times;</span>
      </button>
    </div>

    <div class="era-grid">
      <!-- 1. PDP-11 / VT100 -->
      <div class="era-card coming-soon" data-era="pdp-11">
        <div class="era-card-preview pdp-preview">
          <span class="pdp-text">LOGIN: <span class="blink-cursor">_</span></span>
        </div>
        <div class="era-card-info">
          <div class="era-card-name">
            PDP-11 / VT100
            <span class="era-badge badge-soon">COMING SOON</span>
          </div>
          <span class="era-card-years">1970s&ndash;80s</span>
          <span class="era-card-desc">Green phosphor terminals and blinking cursors</span>
        </div>
      </div>

      <!-- 2. Symbolics Lisp Machine -->
      <div class="era-card coming-soon" data-era="symbolics">
        <div class="era-card-preview symbolics-preview">
          <span class="symbolics-text">Genera 8.3</span>
        </div>
        <div class="era-card-info">
          <div class="era-card-name">
            Symbolics Lisp Machine
            <span class="era-badge badge-soon">COMING SOON</span>
          </div>
          <span class="era-card-years">1980s</span>
          <span class="era-card-desc">The most exotic machine ever built</span>
        </div>
      </div>

      <!-- 3. Apple IIe -->
      <div class="era-card coming-soon" data-era="apple-iie">
        <div class="era-card-preview apple-preview">
          <span class="apple-text">]CATALOG</span>
        </div>
        <div class="era-card-info">
          <div class="era-card-name">
            Apple IIe
            <span class="era-badge badge-soon">COMING SOON</span>
          </div>
          <span class="era-card-years">1983</span>
          <span class="era-card-desc">40 columns of Applesoft BASIC</span>
        </div>
      </div>

      <!-- 4. BBS / ANSI Art -->
      <div class="era-card coming-soon" data-era="bbs">
        <div class="era-card-preview bbs-preview">
          <div class="bbs-border">&boxH;&boxH;&boxH;&boxH;&boxH;&boxH;&boxH;&boxH;&boxH;&boxH;&boxH;&boxH;&boxH;&boxH;</div>
          <span class="bbs-text">WELCOME</span>
          <div class="bbs-border">&boxH;&boxH;&boxH;&boxH;&boxH;&boxH;&boxH;&boxH;&boxH;&boxH;&boxH;&boxH;&boxH;&boxH;</div>
        </div>
        <div class="era-card-info">
          <div class="era-card-name">
            BBS / ANSI Art
            <span class="era-badge badge-soon">COMING SOON</span>
          </div>
          <span class="era-card-years">Late 80s&ndash;90s</span>
          <span class="era-card-desc">14.4k modems and ASCII art</span>
        </div>
      </div>

      <!-- 5. Sun SPARCstation / OpenLook -->
      <div class="era-card coming-soon" data-era="sun-sparc">
        <div class="era-card-preview sun-preview">
          <div class="sun-pushpin"></div>
          <div class="sun-scrollbar">
            <div class="sun-scroll-thumb"></div>
          </div>
          <span class="sun-text">cmdtool</span>
        </div>
        <div class="era-card-info">
          <div class="era-card-name">
            Sun SPARCstation
            <span class="era-badge badge-soon">COMING SOON</span>
          </div>
          <span class="era-card-years">Early 90s</span>
          <span class="era-card-desc">Rounded pushpins and distinctive scrollbars</span>
        </div>
      </div>

      <!-- 6. SGI IRIX 6.5 [CURRENT] -->
      <div class="era-card era-current" data-era="sgi-irix">
        <div class="era-card-preview sgi-preview">
          <div class="sgi-titlebar">
            <span class="sgi-title-text">Indigo Magic</span>
          </div>
          <div class="sgi-desktop"></div>
        </div>
        <div class="era-card-info">
          <div class="era-card-name">
            SGI IRIX 6.5
            <span class="era-badge badge-current">CURRENT</span>
          </div>
          <span class="era-card-years">Mid 90s</span>
          <span class="era-card-desc">The purple-teal Indigo Magic desktop</span>
        </div>
      </div>

      <!-- 7. NeXTSTEP -->
      <div class="era-card coming-soon" data-era="nextstep">
        <div class="era-card-preview next-preview">
          <div class="next-panel">
            <div class="next-inner"></div>
          </div>
        </div>
        <div class="era-card-info">
          <div class="era-card-name">
            NeXTSTEP
            <span class="era-badge badge-soon">COMING SOON</span>
          </div>
          <span class="era-card-years">Late 80s&ndash;Early 90s</span>
          <span class="era-card-desc">Dark gray panels. Where the web was born.</span>
        </div>
      </div>

      <!-- 8. BeOS -->
      <div class="era-card coming-soon" data-era="beos">
        <div class="era-card-preview beos-preview">
          <div class="beos-tab-bar">
            <div class="beos-tab">Tracker</div>
          </div>
          <div class="beos-window-body"></div>
        </div>
        <div class="era-card-info">
          <div class="era-card-name">
            BeOS
            <span class="era-badge badge-soon">COMING SOON</span>
          </div>
          <span class="era-card-years">Late 90s</span>
          <span class="era-card-desc">Yellow tab bars. Ahead of its time.</span>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* ─── Overlay backdrop ─── */
  .era-picker-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.85);
    z-index: 20000;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    overflow-y: auto;
    padding: 40px 16px;
  }

  /* ─── Container ─── */
  .era-picker-content {
    background: linear-gradient(180deg, #4a4a52 0%, #3a3a42 100%);
    border: 2px outset #666;
    border-radius: 4px;
    padding: 24px;
    max-width: 820px;
    width: 100%;
    box-shadow:
      0 0 60px rgba(107, 63, 160, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
  }

  /* ─── Header ─── */
  .era-picker-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 20px;
    gap: 16px;
  }

  .era-picker-title {
    color: #e0d0f0;
    font-size: 18px;
    font-weight: bold;
    margin: 0 0 4px 0;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.5);
  }

  .era-picker-subtitle {
    color: #999;
    font-size: 13px;
    margin: 0;
    font-style: italic;
  }

  /* ─── Close button (SGI widget style) ─── */
  .era-close-btn {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    background: linear-gradient(180deg, #6a6a72 0%, #4a4a52 100%);
    border: 2px outset #777;
    border-radius: 2px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    transition: background 0.1s;
  }

  .era-close-btn:hover {
    background: linear-gradient(180deg, #7a7a82 0%, #5a5a62 100%);
  }

  .era-close-btn:active {
    border-style: inset;
  }

  .era-close-x {
    color: #ddd;
    font-size: 20px;
    line-height: 1;
  }

  /* ─── Grid ─── */
  .era-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  @media (min-width: 900px) {
    .era-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 560px) {
    .era-grid {
      grid-template-columns: 1fr;
    }
    .era-picker-content {
      padding: 16px;
    }
  }

  /* ─── Card base ─── */
  .era-card {
    height: 180px;
    border: 2px solid #555;
    border-radius: 4px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    background: #2a2a30;
    transition: transform 0.2s, border-color 0.2s;
    position: relative;
  }

  /* ─── Coming Soon cards ─── */
  .era-card.coming-soon {
    opacity: 0.5;
    cursor: default;
  }

  .era-card.coming-soon:hover {
    opacity: 0.65;
  }

  /* ─── Current card ─── */
  .era-card.era-current {
    border-color: #6B3FA0;
    cursor: default;
    animation: current-glow 3s ease-in-out infinite;
  }

  @keyframes current-glow {
    0%, 100% {
      box-shadow: 0 0 8px rgba(107, 63, 160, 0.4), 0 0 20px rgba(58, 138, 122, 0.2);
    }
    50% {
      box-shadow: 0 0 16px rgba(107, 63, 160, 0.7), 0 0 32px rgba(58, 138, 122, 0.4);
    }
  }

  /* ─── Preview area (top 60%) ─── */
  .era-card-preview {
    flex: 1 1 60%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
  }

  /* ─── Info area (bottom 40%) ─── */
  .era-card-info {
    flex: 0 0 auto;
    padding: 8px 10px;
    background: #1e1e24;
    border-top: 1px solid #444;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .era-card-name {
    color: #e0e0e0;
    font-size: 12px;
    font-weight: bold;
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  .era-card-years {
    color: #888;
    font-size: 11px;
  }

  .era-card-desc {
    color: #777;
    font-size: 10px;
    font-style: italic;
    line-height: 1.3;
  }

  /* ─── Badges ─── */
  .era-badge {
    font-size: 9px;
    font-weight: bold;
    padding: 1px 6px;
    border-radius: 3px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    white-space: nowrap;
  }

  .badge-current {
    background: linear-gradient(135deg, #6B3FA0, #3A8A7A);
    color: #fff;
  }

  .badge-soon {
    background: #444;
    color: #999;
    border: 1px solid #555;
  }

  /* ═══════════════════════════════════════════
     CSS Art Previews
     ═══════════════════════════════════════════ */

  /* 1. PDP-11 / VT100 */
  .pdp-preview {
    background: #000;
    font-family: "Courier New", Courier, monospace;
  }

  .pdp-text {
    color: #33ff33;
    font-size: 16px;
    text-shadow: 0 0 6px rgba(51, 255, 51, 0.6);
    letter-spacing: 2px;
  }

  .blink-cursor {
    animation: blink-green 1s step-end infinite;
  }

  @keyframes blink-green {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  /* 2. Symbolics Lisp Machine */
  .symbolics-preview {
    background: #0a0a3a;
  }

  .symbolics-text {
    color: #e0e0e0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 18px;
    letter-spacing: 1px;
    text-shadow: 0 0 4px rgba(200, 200, 255, 0.3);
  }

  /* 3. Apple IIe */
  .apple-preview {
    background: #000;
    font-family: "Courier New", Courier, monospace;
  }

  .apple-text {
    color: #33ff33;
    font-size: 18px;
    font-weight: bold;
    text-shadow: 0 0 4px rgba(51, 255, 51, 0.5);
    letter-spacing: 3px;
  }

  /* 4. BBS / ANSI Art */
  .bbs-preview {
    background: #000;
    flex-direction: column;
    gap: 4px;
    font-family: "Courier New", Courier, monospace;
  }

  .bbs-border {
    color: #00cccc;
    font-size: 12px;
    letter-spacing: 1px;
    text-shadow: 0 0 4px rgba(0, 204, 204, 0.5);
  }

  .bbs-text {
    color: #cc44cc;
    font-size: 16px;
    font-weight: bold;
    letter-spacing: 3px;
    text-shadow: 0 0 6px rgba(204, 68, 204, 0.5);
  }

  /* 5. Sun SPARCstation / OpenLook */
  .sun-preview {
    background: #c0c0c0;
    position: relative;
    gap: 0;
  }

  .sun-pushpin {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: radial-gradient(circle at 40% 40%, #fff, #888);
    border: 1px solid #666;
    position: absolute;
    top: 8px;
    left: 10px;
    box-shadow: 1px 1px 2px rgba(0, 0, 0, 0.3);
  }

  .sun-scrollbar {
    position: absolute;
    right: 8px;
    top: 12px;
    bottom: 12px;
    width: 18px;
    background: #aaa;
    border-radius: 9px;
    border: 1px solid #888;
  }

  .sun-scroll-thumb {
    width: 14px;
    height: 24px;
    background: linear-gradient(180deg, #ddd, #999);
    border-radius: 7px;
    border: 1px solid #777;
    margin: 4px auto 0;
  }

  .sun-text {
    color: #222;
    font-family: "Courier New", Courier, monospace;
    font-size: 13px;
    position: absolute;
    bottom: 10px;
    left: 10px;
  }

  /* 6. SGI IRIX 6.5 */
  .sgi-preview {
    background: linear-gradient(135deg, #2a1a40 0%, #1a3a35 100%);
    flex-direction: column;
    align-items: stretch;
    padding: 0;
  }

  .sgi-titlebar {
    background: linear-gradient(90deg, #6B3FA0, #3A8A7A);
    padding: 3px 8px;
    flex: 0 0 auto;
  }

  .sgi-title-text {
    color: #fff;
    font-size: 11px;
    font-weight: bold;
    text-shadow: 0 1px 1px rgba(0, 0, 0, 0.5);
  }

  .sgi-desktop {
    flex: 1;
    background:
      radial-gradient(circle at 30% 60%, rgba(107, 63, 160, 0.3) 0%, transparent 50%),
      radial-gradient(circle at 70% 40%, rgba(58, 138, 122, 0.3) 0%, transparent 50%),
      linear-gradient(180deg, #1a1028 0%, #0f2520 100%);
  }

  /* 7. NeXTSTEP */
  .next-preview {
    background: #333;
  }

  .next-panel {
    width: 80%;
    height: 70%;
    background: linear-gradient(180deg, #4a4a4a 0%, #3a3a3a 100%);
    border: 2px outset #555;
    border-radius: 1px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4px;
  }

  .next-inner {
    width: 100%;
    height: 100%;
    background: #1a1a1a;
    border: 1px inset #333;
  }

  /* 8. BeOS */
  .beos-preview {
    background: #d8d8d8;
    flex-direction: column;
    align-items: stretch;
    padding: 0;
  }

  .beos-tab-bar {
    display: flex;
    padding: 0;
    flex: 0 0 auto;
  }

  .beos-tab {
    background: #FFD700;
    color: #333;
    font-size: 11px;
    font-weight: bold;
    padding: 3px 12px;
    border-right: 1px solid #cca800;
    border-bottom: 1px solid #cca800;
  }

  .beos-window-body {
    flex: 1;
    background: #e8e8e8;
    border-top: 1px solid #fff;
  }
</style>

<script>
  // Close on button click
  document.getElementById("era-picker-close")?.addEventListener("click", () => {
    const picker = document.getElementById("era-picker");
    if (picker) picker.style.display = "none";
  });

  // Close on Escape key
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      const picker = document.getElementById("era-picker");
      if (picker && picker.style.display !== "none") {
        picker.style.display = "none";
      }
    }
  });

  // Close on backdrop click (not on content)
  document.getElementById("era-picker")?.addEventListener("click", (e) => {
    if ((e.target as HTMLElement).classList.contains("era-picker-overlay")) {
      const picker = document.getElementById("era-picker");
      if (picker) picker.style.display = "none";
    }
  });
</script>
