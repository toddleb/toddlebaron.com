---
// src/pages/index.astro — BBS Terminal (default landing page)
import BBS from "../layouts/BBS.astro";
import Boot from "../themes/bbs/Boot.astro";
import Terminal from "../themes/bbs/Terminal.astro";
import { getCollection, render } from "astro:content";

const pages = (await getCollection("pages")).sort((a, b) => a.data.order - b.data.order);
const blog = await getCollection("blog");
---

<BBS>
  <Boot />

  <div id="bbs-main" style="display:none">
    <Terminal>
      {await Promise.all(pages.map(async (page) => {
        const { Content } = await render(page);
        const isBlog = page.data.windowId === "blog";
        return (
          <section
            id={`bbs-screen-${page.data.windowId}`}
            class="bbs-screen"
          >
            <pre class="bbs-section-header"><span class="ansi-cyan">═══════════════════════════════════════════════</span>
<span class="ansi-bright-yellow">  {page.data.title.toUpperCase()}</span>
<span class="ansi-cyan">═══════════════════════════════════════════════</span></pre>

            <div class="bbs-section-body">
              <Content />
              {isBlog && blog.length > 0 && (
                <div class="bbs-blog-list">
                  {blog.sort((a, b) => b.data.date.getTime() - a.data.date.getTime()).map((post) => (
                    <a href={`/blog/${post.id}`} class="bbs-blog-entry">
                      <span class="ansi-bright-white">{post.data.title}</span>
                      <span class="bbs-blog-date">{post.data.date.toLocaleDateString()}</span>
                    </a>
                  ))}
                </div>
              )}
            </div>

            <div class="bbs-return" data-bbs-back>
              <span class="ansi-bright-green">Press [ESC] to return to Main Menu</span>
            </div>
          </section>
        );
      }))}
    </Terminal>
  </div>
</BBS>
